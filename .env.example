# ============================================
# 🔒 ORTAM DEGISKENLERI - ENVIRONMENT VARIABLES
# ============================================
# Bu dosyayi .env olarak kopyalay ve degerleri guncelle
# ASLA .env dosyasini GitHub'a COMMIT ETMEYIN!
# ===========================================

# ============================================
# BACKEND AYARLARI
# ============================================
PORT=5000
NODE_ENV=development
# Production icin: NODE_ENV=production

# ============================================
# JWT SECREYLERI - Cok Guclu Random String
# ============================================
# Olustur: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_burada_guvenlice_tutun
JWT_EXPIRE=7d

# ============================================
# MONGODB / DATABASE
# ============================================
MONGODB_URI=mongodb://localhost:27017/anigram
# Production icin:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/anigram?retryWrites=true&w=majority

# ============================================
# SUPABASE - Database & Auth
# ============================================
# https://supabase.com adresinden al
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key_burada
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_super_gizli

# ============================================
# API KEYS - Cok Gizli Tut!
# ============================================
# YouTube API: https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_burada

# ============================================
# FRONTEND AYARLARI
# ============================================
FRONTEND_URL=http://localhost:3000
# Production icin: FRONTEND_URL=https://yourdomain.com

# Frontend'ten API'ye baglanti
REACT_APP_API_URL=http://localhost:5000/api
# Production icin: REACT_APP_API_URL=https://api.yourdomain.com/api

# ============================================
# EMAIL AYARLARI (OPSIYONEL)
# ============================================
# EMAIL_SERVICE=gmail
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# ============================================
# LOGLAMA
# ============================================
LOG_LEVEL=info
# Production icin: LOG_LEVEL=error

# ============================================
# SECURUTY / GÜVENLIK
# ============================================
# CORS Rate Limiting (istek/dakika)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Login Rate Limiting (5 deneme/15 dakika)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_TIME_MS=900000

# ============================================
# DIKKAT - ASLA GITHUB'A COMMIT ETME
# ============================================
# .gitignore dosyasinda .env var
# Git push oncesi kontrol et: git status
